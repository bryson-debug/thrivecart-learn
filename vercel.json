{
  "functions": {
    "api/sidepanel-serve.js": {
      "maxDuration": 10,
      "includeFiles": "public/sidepanel/**"
    },
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/sidepanel", "destination": "/api/sidepanel-serve" },
    { "source": "/sidepanel/:path*", "destination": "/api/sidepanel-serve?path=:path*" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "public"
}
